# DitakNet public website / customer portal environment template.
# Copy to .env and replace every change-me / empty production value.
# Never commit a real .env file.

# --- Database ---
# Local SQLite (development). For PostgreSQL, use a postgres:// URL instead.
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Generate a long random secret (32+ bytes). Required in production.
NEXTAUTH_SECRET="change-me-generate-a-random-32-byte-secret"
# Public URL users open in the browser (scheme + host, no trailing path).
NEXTAUTH_URL="https://ditaknet.example.com"

# --- Bootstrap admin (used by seed / first setup) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-use-a-strong-private-password"
ADMIN_NAME="DitakNet Admin"

# --- Branding / support channels ---
APP_NAME="DitakNet"
APP_DISPLAY_NAME="DitakNet"
APP_BRAND_NAME="DitakNet"
APP_BRAND_NAME_HY="DitakNet"
APP_SUPPORT_EMAIL=""
APP_SUPPORT_PHONE=""
APP_SUPPORT_TELEGRAM=""
APP_SUPPORT_URL=""
APP_DOCUMENTATION_URL=""
NEXT_PUBLIC_DEFAULT_LOCALE="hy"

# --- Optional SMTP (if empty, messages stay in DB) ---
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# --- Optional publish port for docker compose ---
# WEB_PORT=3000

# --- Optional Cloudflare / public domain helpers ---
# Keep tunnel tokens and API tokens on the server only — never in client code.
PUBLIC_DOMAIN="ditaknet.example.com"
CLOUDFLARE_TUNNEL_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ZONE_ID=""
